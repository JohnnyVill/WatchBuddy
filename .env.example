# TMDB API key (Bearer token from https://www.themoviedb.org/settings/api)
TMDB_API_KEY=

# PostgreSQL connection string (e.g., Neon, Supabase)
DATABASE_URL=

# Secret key for session JWT signing (generate with: openssl rand -base64 32)
SESSION_SECRET=

# Upstash Redis (for rate limiting)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
